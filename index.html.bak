                tab_basic: '基础设定', tab_cosmetics: '外观改装', tab_security: '安全协议', cat_bg: '作战视界', cat_frame: '特工边框', cat_card: '全息卡槽',
                bm_title: '黑市 (MARKET)', bm_credits: '可用信用点', bm_buy: '解密购买', bm_locked: '权限锁定', bm_unlocked: '已解密', bm_desc: '在此消耗实战获取的信用点，直接购买基础外观。',
